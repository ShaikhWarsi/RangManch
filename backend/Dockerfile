FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY tsconfig.json ./
COPY src ./src

RUN npm run build

FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=7860

COPY package*.json ./
COPY .env ./
RUN npm install --omit=dev

COPY --from=builder /app/dist ./dist

EXPOSE 7860

CMD ["node", "dist/server.js"]