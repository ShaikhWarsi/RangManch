# ===========================================
# RANGMANCH - ENVIRONMENT VARIABLES
# ===========================================

# Firebase Configuration (Required for real authentication)
# Get these from your Firebase Console → Project Settings → General
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ===========================================
# AI CONFIGURATION
# ===========================================

# Groq API Key for AI Craft Recommender
# Get your free API key from https://groq.com/
NEXT_PUBLIC_GROQ_API_KEY=your_groq_api_key_here

# ===========================================
# DEMO MODE NOTES
# ===========================================
# If Firebase variables are not set, the app runs in demo mode automatically
# Demo credentials are built-in for testing:
#   - buyer@demo.com / demo123
#   - artisan@demo.com / demo123  
#   - ngo@demo.com / demo123

# ===========================================
# OPTIONAL CONFIGURATIONS
# ===========================================

# Custom Domain (if deploying to custom domain)
NEXT_PUBLIC_DOMAIN=rangmanch.com

# Analytics (if using Google Analytics)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# API Configuration (if using external APIs)
NEXT_PUBLIC_API_BASE_URL=https://api.rangmanch.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key

# Backend API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================
# 1. Copy this file to .env.local
# 2. Fill in your actual Firebase credentials
# 3. Run: npm install && npm run dev
# 4. Visit: http://localhost:3000

# ===========================================
# TROUBLESHOOTING
# ===========================================
# Firebase not working? 
# - Check that all Firebase variables are correctly set
# - Verify Firebase project has Authentication enabled
# - Ensure email/password auth is enabled in Firebase Console

# Build errors?
# - Run: npm run build
# - Check that all environment variables are available
# - Verify Node.js version is 18+

# Application Configuration
NODE_ENV=development
